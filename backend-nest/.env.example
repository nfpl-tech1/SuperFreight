# --------------------------------------------------------------------
# SuperFreight - NestJS Backend Environment Variables
# Copy this file to .env and fill in your values.
# --------------------------------------------------------------------

# Server
PORT=8000
NODE_ENV=development

# --------------------------------------------------------------------
# App Database (superfreight_app)
# Stores app-local workflow, auth cache, roles, RFQs, quotes, drafts,
# Outlook connection state, and audit logs.
# --------------------------------------------------------------------
APP_DB_HOST=localhost
APP_DB_PORT=5432
APP_DB_USERNAME=postgres
APP_DB_PASSWORD=your_app_db_password
APP_DB_NAME=superfreight_app
APP_DB_MIGRATIONS_RUN=false

# --------------------------------------------------------------------
# Shared Business Database (logistics_business_core)
# Stores shared business data for future cross-app reuse with CHA.
# --------------------------------------------------------------------
BUSINESS_DB_HOST=localhost
BUSINESS_DB_PORT=5432
BUSINESS_DB_USERNAME=postgres
BUSINESS_DB_PASSWORD=your_business_db_password
BUSINESS_DB_NAME=logistics_business_core
BUSINESS_DB_MIGRATIONS_RUN=false

# --------------------------------------------------------------------
# Legacy fallback DB vars
# Optional. Only keep if you want APP/BUSINESS DB vars to inherit defaults.
# --------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_MIGRATIONS_RUN=false

# --------------------------------------------------------------------
# Internal JWT for SuperFreight sessions
# --------------------------------------------------------------------
JWT_SECRET=change_this_superfreight_jwt_secret
JWT_EXPIRES_IN=30m

# --------------------------------------------------------------------
# OS Identity Integration
# SuperFreight now uses OS for login and SSO verification.
# --------------------------------------------------------------------
OS_APP_SLUG=super-freight
OS_BACKEND_URL=http://localhost:3001
INTERNAL_API_KEY=replace_with_same_internal_key_used_by_os

# Optional: if provided, SuperFreight can verify OS SSO tokens locally
# without fetching the key from OS /auth/public-key.
OS_JWT_PUBLIC_KEY=

# --------------------------------------------------------------------
# Microsoft / Outlook Integration
# Used for mandatory mailbox onboarding after app login.
# --------------------------------------------------------------------
MICROSOFT_CLIENT_ID=your_azure_client_id
MICROSOFT_TENANT_ID=your_azure_tenant_id
MICROSOFT_CLIENT_SECRET=your_azure_client_secret
MICROSOFT_REDIRECT_URI=http://localhost:3000/onboarding

# Optional: public webhook endpoint to receive Graph notifications later
MICROSOFT_WEBHOOK_URL=

# --------------------------------------------------------------------
# Gemini
# Used later for inquiry classification and quote extraction.
# --------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# --------------------------------------------------------------------
# Frontend / CORS
# Set this to the deployed frontend origin so the backend accepts
# browser-originated requests and proxied requests that preserve Origin.
# Use FRONTEND_URLS for multiple allowed origins, comma-separated.
# --------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
# FRONTEND_URLS=http://localhost:3000,https://app.superfreight.example.com

# --------------------------------------------------------------------
# Notes
# 1. In OS, the application slug must be: super-freight
# 2. Your test user must have SuperFreight access in OS
# 3. Apply schema changes with `npm run migration:run`
# 4. Leave synchronize disabled; the app now uses explicit TypeORM migrations
# --------------------------------------------------------------------
