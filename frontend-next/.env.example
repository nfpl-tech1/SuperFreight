NEXT_PUBLIC_MICROSOFT_CLIENT_ID=your_azure_client_id
NEXT_PUBLIC_MICROSOFT_TENANT_ID=your_azure_tenant_id
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000

# Either set `BACKEND_API_ORIGIN` to the backend origin,
# or set `NEXT_PUBLIC_API_URL` to the full backend /api URL.
# The frontend proxy prefers `BACKEND_API_ORIGIN` when both are present.
# Examples:
# BACKEND_API_ORIGIN=https://api.superfreight.example.com
# NEXT_PUBLIC_API_URL=https://api.superfreight.example.com/api
BACKEND_API_ORIGIN=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000/api
